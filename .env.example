# Copy to `.env` and fill in. Never commit `.env`.

# --- Duffel (complete KYC for live; test token for development)
# https://duffel.com — after onboarding, fund balance for instant orders.
DUFFEL_ACCESS_TOKEN=

# --- Database (Neon Postgres)
DATABASE_URL=

# --- Auth session signing (random 32+ chars)
SESSION_SECRET=

# --- Email (Resend) — 6-digit login codes & booking emails
RESEND_API_KEY=
# Verified domain in Resend (no @). From address = EMAIL_FROM_LOCAL + @ + EMAIL_DOMAIN
EMAIL_DOMAIN=
# Optional; default noreply. Use "onboarding" with domain resend.dev for Resend trials
# EMAIL_FROM_LOCAL=noreply

# --- Stripe — service fee checkout + webhook after payment
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional branding
NEXT_PUBLIC_APP_NAME=TempTicket

# --- Optional: machine-translate messages/*.json (see npm run translate:messages)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
